rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check role from custom claims OR users/{uid} document
    function hasRole(role) {
      return request.auth != null && (
        request.auth.token.role == role ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role)
      );
    }

    function hasAnyRole(roles) {
      return request.auth != null && (
        request.auth.token.role in roles ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles)
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // Loans collection
    match /loans/{loanId} {
      allow read: if request.auth != null;
      allow create: if hasAnyRole(['admin', 'bookkeeper']);
      allow update: if hasAnyRole(['admin', 'bookkeeper', 'approver', 'payrollChecker']);
      // Admins: delete any loan. Bookkeepers: delete pending loans only.
      allow delete: if hasRole('admin') || (hasRole('bookkeeper') && resource.data.status == 'pending');

      // Payments subcollection
      match /payments/{paymentId} {
        allow read: if request.auth != null;
        allow create: if hasAnyRole(['admin', 'bookkeeper']);
        allow update: if hasAnyRole(['admin', 'bookkeeper']) ||
          (hasRole('approver') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['penaltyWaived', 'penaltyDenied', 'amount', 'updatedAt']));
        // Bookkeepers need delete permission to cascade-delete when removing a pending loan
        allow delete: if hasAnyRole(['admin', 'bookkeeper']);
      }
    }

    // Counters collection (for auto-incrementing loan numbers)
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if hasAnyRole(['admin', 'bookkeeper']);
    }

    // Settings collection (penalty settings, etc.)
    match /settings/{document=**} {
      allow read: if request.auth != null;
      allow write: if hasRole('admin');
    }

    // Loan Types collection (drives Service/Loan Category dropdown)
    match /loanTypes/{typeId} {
      allow read: if request.auth != null;
      allow write: if hasRole('admin');
    }

    // Loan Purposes collection (drives Intended Purpose dropdown)
    match /loanPurposes/{purposeId} {
      allow read: if request.auth != null;
      allow write: if hasRole('admin');
    }
  }
}
