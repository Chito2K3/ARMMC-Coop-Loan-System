rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Instead of helper functions, use explicit role checks below that
    // accept either auth custom claim `request.auth.token.role` OR a
    // `users/{uid}` document containing `.role`.
    
    // Users collection - protect role field from unauthorized changes
    match /users/{userId} {
      // Anyone authenticated can read user documents
      allow read: if request.auth != null;
      
      // Prevent users from changing their own role or deleting users
      allow update: if request.auth != null && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      
      // Only allow user creation (for new sign-ups via AuthGuard)
      allow create: if request.auth != null;
      
      // Prevent deletion from client side
      allow delete: if false;
    }

    // Loans collection - role-based access
    match /loans/{loanId} {
      // All authenticated users can read loans
      allow read: if request.auth != null;
      
      // Only bookkeepers and admins can create loans
      allow create: if request.auth != null && (
        request.auth.token.role in ['admin', 'bookkeeper'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper'])
      );

      // Bookkeepers, approvers, payrollChecker and admins can update loans
      // Note: Clients cannot modify automated penalty bucket fields (handled by Cloud Functions)
      allow update: if request.auth != null && (
        request.auth.token.role in ['admin', 'bookkeeper', 'approver', 'payrollChecker'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper', 'approver', 'payrollChecker'])
      ) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['historical_shortfall_bucket', 'final_surcharge_total']));

      // Only admins can delete loans
      allow delete: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
      
      // Payments subcollection
      match /payments/{paymentId} {
        // All authenticated users can read payments
        allow read: if request.auth != null;
        
        // Bookkeepers and admins can create and update all payment fields
        allow create: if request.auth != null && (
          request.auth.token.role in ['admin', 'bookkeeper'] ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper'])
        );
        allow update: if request.auth != null && (
          request.auth.token.role in ['admin', 'bookkeeper'] ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper'])
        );

        // Only admins can delete payments
        allow delete: if request.auth != null && (
          request.auth.token.role == 'admin' ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
      }
    }

    // Counters collection - for auto-incrementing loan numbers
    match /counters/{counterId} {
      // All authenticated users can read counters
      allow read: if request.auth != null;
      
      // Only bookkeepers and admins can update counters
      allow write: if request.auth != null && (
        request.auth.token.role in ['admin', 'bookkeeper'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper'])
      );
    }

    // Settings collection - for penalty settings
    match /settings/{document=**} {
      // All authenticated users can read settings
      allow read: if request.auth != null;
      
      // Only admins can update settings
      allow write: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
  }
}
