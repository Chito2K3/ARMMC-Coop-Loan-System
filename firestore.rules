rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Instead of helper functions, use explicit role checks below that
    // accept either auth custom claim `request.auth.token.role` OR a
    // `users/{uid}` document containing `.role`.
    
    // Users collection - protect role field from unauthorized changes
    match /users/{userId} {
      // Anyone authenticated can read user documents
      allow read: if request.auth != null;
      
      // Allow user creation and migration (including role field for migration)
      // Allow admins (via token or Firestore doc) to manage any user
      allow create, update: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
      
      // Allow admins to delete users
      allow delete: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Loans collection - role-based access
    match /loans/{loanId} {
      // All authenticated users can read loans
      allow read: if request.auth != null;
      
      // Only bookkeepers and admins can create loans
      allow create: if request.auth != null && (
        request.auth.token.role in ['admin', 'bookkeeper'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper'])
      );

      // Bookkeepers, committee members/officers, payrollChecker and admins can update loans
      allow update: if request.auth != null && (
        request.auth.token.role in ['admin', 'bookkeeper', 'creditCommitteeMember', 'creditCommitteeOfficer', 'payrollChecker'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper', 'creditCommitteeMember', 'creditCommitteeOfficer', 'payrollChecker'])
      ) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['historical_shortfall_bucket', 'final_surcharge_total']));

      // Only admins can delete loans
      allow delete: if request.auth != null && (
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
      
      // Payments subcollection
      match /payments/{paymentId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (
          request.auth.token.role in ['admin', 'bookkeeper'] ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'bookkeeper'])
        );
      }
    }

    // Counters collection
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Simpler for now
    }

    // Settings collection - anyone authenticated can read/write for now to fix initialization
    match /settings/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Loan Types & Purposes - anyone authenticated can read/write during transition
    match /loanTypes/{typeId} {
      allow read, write: if request.auth != null;
    }
    match /loanPurposes/{purposeId} {
      allow read, write: if request.auth != null;
    }
  }
}
